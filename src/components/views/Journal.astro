---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

import site from "~/data/site.yaml";
import {
  byLocale,
  entrySlug,
  localeCodes,
  localizedPath,
  toLocale,
  useTranslations,
} from "~/i18n/ui";
import Layout from "~/layouts/Layout.astro";

const locale = toLocale(Astro.currentLocale);
const t = useTranslations(locale);
const inLocale = byLocale(locale);

const entries = (
  await getCollection(
    "journal",
    (e) => inLocale(e) && (import.meta.env.DEV || !e.data.draft),
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const byYear = new Map<number, CollectionEntry<"journal">[]>();
for (const entry of entries) {
  const year = entry.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(entry);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const month = (date: Date) =>
  date.toLocaleDateString(localeCodes[locale], { month: "short" });
---

<Layout title={`${t("journal.title")} — ${site.name}`}>
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-semibold tracking-tight">{t("journal.title")}</h1>
    <p class="mt-3 max-w-xl leading-relaxed text-muted">{t("journal.intro")}</p>

    {
      entries.length > 0 ? (
        <div class="mt-12 space-y-10">
          {years.map((year) => (
            <section>
              <h2 class="font-mono text-sm tracking-widest text-muted">{year}</h2>
              <ul class="mt-3 divide-y divide-line/60">
                {byYear.get(year)!.map((entry) => (
                  <li>
                    <a
                      href={localizedPath(locale, `/journal/${entrySlug(entry.id)}`)}
                      class="group flex items-center gap-4 py-3 text-muted transition-colors hover:text-text"
                    >
                      <span class="w-10 shrink-0 font-mono text-xs">
                        {month(entry.data.date)}
                      </span>
                      <span class="flex-1 text-text">{entry.data.title}</span>
                      <span class="hidden shrink-0 rounded-full border border-line px-2 py-0.5 font-mono text-xs sm:inline">
                        {t(`type.${entry.data.type}`)}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      ) : (
        <p class="mt-12 text-muted">{t("journal.empty")}</p>
      )
    }
  </div>
</Layout>
