---
import { getCollection } from "astro:content";

import site from "~/data/site.yaml";
import Layout from "~/layouts/Layout.astro";

const experience = (await getCollection("experience")).sort(
  (a, b) => b.data.start.valueOf() - a.data.start.valueOf(),
);

const formatMonth = (date?: Date) =>
  date
    ? date.toLocaleDateString("en-US", { month: "short", year: "numeric" })
    : "present";
---

<Layout
  title={`Experience — ${site.name}`}
  description={`Work history of ${site.name}.`}
>
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-semibold tracking-tight">Experience</h1>
    <ol class="mt-12 space-y-11 border-l border-line pl-6">
      {
        experience.map(({ data: job }) => (
          <li class="reveal relative">
            <span class="absolute top-[7px] -left-[30px] h-2.5 w-2.5 rounded-full bg-accent ring-4 ring-bg" />
            <h2 class="font-medium">
              {job.role} <span class="text-muted">· {job.company}</span>
            </h2>
            <p class="mt-1 font-mono text-xs text-muted">
              {formatMonth(job.start)} — {formatMonth(job.end)}
            </p>
            <ul class="mt-3 list-disc space-y-1.5 pl-4 text-sm leading-relaxed text-muted">
              {job.highlights.map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
            <ul class="mt-3 flex flex-wrap gap-2" aria-label="Technologies">
              {job.tags.map((tag) => (
                <li class="rounded-full border border-line px-2 py-0.5 font-mono text-xs text-muted">
                  {tag}
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>
  </div>
</Layout>
