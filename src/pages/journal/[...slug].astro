---
import { getCollection, render } from "astro:content";

import site from "~/data/site.yaml";
import Layout from "~/layouts/Layout.astro";

export async function getStaticPaths() {
  const entries = await getCollection(
    "journal",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });

const typeLabels: Record<string, string> = {
  "case-study": "Case study",
  note: "Note",
  experiment: "Experiment",
};
---

<Layout
  title={`${entry.data.title} — ${site.name}`}
  description={entry.data.summary}
>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <a href="/journal" class="font-mono text-xs text-muted hover:text-accent"
      >← Journal</a
    >
    <div class="mt-8 flex items-center gap-3 font-mono text-xs text-muted">
      <span>{formatDate(entry.data.date)}</span>
      <span class="rounded-full border border-line px-2 py-0.5">
        {typeLabels[entry.data.type]}
      </span>
    </div>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">
      {entry.data.title}
    </h1>
    <p class="mt-3 text-lg leading-relaxed text-muted">{entry.data.summary}</p>
    <div class="prose mt-10">
      <Content />
    </div>
    {
      entry.data.tags.length > 0 && (
        <ul class="mt-12 flex flex-wrap gap-2" aria-label="Tags">
          {entry.data.tags.map((tag) => (
            <li class="rounded-full border border-line px-2 py-0.5 font-mono text-xs text-muted">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </article>
</Layout>
